generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DocumentIntake {
  id                 String            @id @default(uuid())
  status             Status            @default(UPLOADED)
  sourceFilename     String
  sourceMimeType     String
  sourceStorageKey   String
  sourceSha256       String
  generatedTitle     String?
  generatedSummary   String?
  generatedBodyHtml  String?
  detectedLanguage   String?
  editedTitle        String?
  editedSummary      String?
  editedBodyHtml     String?
  editedLanguage     String?
  parserVersion      String?
  parseWarnings      String[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  publishedArticleId String?
  publishedArticle   PublishedArticle? @relation(fields: [publishedArticleId], references: [id])

  @@map("document_intake")
}

model PublishedArticle {
  id          String           @id @default(uuid())
  slug        String           @unique
  title       String
  summary     String
  bodyHtml    String
  language    String
  publishedAt DateTime         @default(now())
  createdAt   DateTime         @default(now())
  intakes     DocumentIntake[]

  @@map("published_article")
}

enum Status {
  UPLOADED
  PARSING
  PARSED
  READY
  PUBLISHED
  FAILED
}
